# ============================================================
# tw-screener 後端設定檔
# 使用方式：複製此檔案為 .env，並依需求修改
#   cp .env.sample .env
# ============================================================

# 歷史 OHLCV 資料保留年數
# 影響 daily_prices 表的資料量，數字越大磁碟用量越高
# 第一次啟動時，會從今天往回抓取這麼多年的資料（時間較長）
DATA_RETENTION_YEARS=1

# 是否開啟 AI 自然語言篩選功能
# true  - 開啟，需已在本機登入 Claude Code CLI（claude login）
# false - 關閉，自然語言模式會回傳錯誤，手動篩選仍可正常使用
AI_ENABLED=false

# 每日自動抓取資料的時間（24 小時制，HH:MM）
# 建議設在台股收盤後（15:00）至隔日開盤前
# 17:30 為預設值，此時盤後資料通常已完整
FETCH_SCHEDULE_TIME=17:30
